{
    email admin@{$DOMAIN}
}

{$DOMAIN} {
    # Admin routes - served by frontend nginx
    redir /admin /admin/
    handle /admin* {
        reverse_proxy frontend:80
    }

    # WebSocket route phải khai báo trước (handle ưu tiên cao hơn)
    handle /ws* {
        reverse_proxy backend:3001
    }

    # API route
    handle /api* {
        reverse_proxy backend:3001
    }

    # Static Frontend (catch-all)
    handle {
        reverse_proxy frontend:80
    }
}

# Internal HTTP listener for Cloudflare Tunnel (no TLS needed)
:8080 {
    # Admin routes - served by frontend nginx
    redir /admin /admin/
    handle /admin* {
        reverse_proxy frontend:80
    }

    # WebSocket route phải khai báo trước
    handle /ws* {
        reverse_proxy backend:3001
    }

    # API route
    handle /api* {
        reverse_proxy backend:3001
    }

    # Static Frontend (catch-all)
    handle {
        reverse_proxy frontend:80
    }
}
